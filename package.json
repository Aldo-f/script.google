{
  "name": "gmail-reminder-scripts",
  "version": "1.0.0",
  "description": "Google Apps Script projects for automated email reminders",
  "private": true,
  "scripts": {
    "validate": "node scripts/validate.js",
    "push:label": "cd LabelReminder && clasp push --force",
    "push:followup": "cd FollowUpReminder && clasp push --force",
    "pull:label": "cd LabelReminder && clasp pull",
    "pull:followup": "cd FollowUpReminder && clasp pull",
    "login": "clasp login",
    "logout": "clasp logout",
    "list": "clasp list"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2"
  },
  "engines": {
    "node": ">=18"
  }
}
